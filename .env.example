# =============================================
# EmployeeHub 環境変数設定（.env.exampleをコピーして .env を作成してください）
# =============================================

# --- データベース ---
DB_USER=employeehub
DB_PASSWORD=employeehub
DB_NAME=employeehub_db

# --- アプリケーション ---
# 本番環境では必ず強力なランダム文字列に変更すること
SECRET_KEY=dev-secret-key-please-change-in-production
ENVIRONMENT=development

# --- CORS（フロントエンドのURL） ---
CORS_ORIGINS=http://localhost:3000

# --- Google OAuth（任意: 設定しない場合はGoogle認証が無効） ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- ファイルストレージ（任意: 未設定はローカルファイルシステム使用） ---
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=employeehub-files

# --- メール送信（任意: 未設定は通知メールが無効） ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- AI検索（任意: 未設定はAI自然言語検索が無効） ---
ANTHROPIC_API_KEY=
