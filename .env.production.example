# =============================================
# EmployeeHub — Production 環境変数テンプレート
#
# 使用方法:
#   cp .env.production.example .env.production
#   # 各値を AWS リソースの実際の値に書き換える
#   # ⚠️ .env.production は絶対に Git にコミットしないこと
# =============================================

# --- 環境識別 ---
ENVIRONMENT=production

# --- アプリケーション ---
# openssl rand -hex 32 で生成すること（Staging と異なる値を使用）
SECRET_KEY=<replace-with-strong-random-secret>

# --- データベース（AWS RDS PostgreSQL）---
DB_USER=employeehub
DB_PASSWORD=<replace-with-rds-password>
DB_NAME=employeehub_production
# RDS エンドポイントに置き換える
DATABASE_URL=postgresql+asyncpg://employeehub:<password>@<rds-endpoint>:5432/employeehub_production
DATABASE_URL_SYNC=postgresql://employeehub:<password>@<rds-endpoint>:5432/employeehub_production

# --- CORS（フロントエンドの ALB ドメイン）---
CORS_ORIGINS=https://app.employeehub.example.com

# --- Google OAuth ---
GOOGLE_CLIENT_ID=<replace-with-google-client-id>
GOOGLE_CLIENT_SECRET=<replace-with-google-client-secret>

# --- ファイルストレージ（AWS S3）---
# S3_ENDPOINT_URL は空にする（AWS S3 標準エンドポイントを使用）
S3_ENDPOINT_URL=
S3_ACCESS_KEY=<replace-with-iam-access-key>
S3_SECRET_KEY=<replace-with-iam-secret-key>
S3_BUCKET_NAME=employeehub-production

# --- メール送信（AWS SES または SMTP）---
SMTP_HOST=email-smtp.ap-northeast-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=<replace-with-ses-smtp-user>
SMTP_PASSWORD=<replace-with-ses-smtp-password>

# --- AI 検索 ---
ANTHROPIC_API_KEY=<replace-with-anthropic-api-key>
